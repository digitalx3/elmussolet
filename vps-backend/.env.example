# ====== Server ======
PORT=8080
NODE_ENV=production

# Public URL where this backend is reachable. Must match `api_base_url` in admin settings.
PUBLIC_BASE_URL=https://api.elmussolet.com

# Public URL where uploaded media is served. Must match `media_base_url` in admin settings.
MEDIA_BASE_URL=https://media.elmussolet.com

# Filesystem path where uploads are stored (served by Nginx/Caddy at MEDIA_BASE_URL).
UPLOAD_DIR=/var/www/elmussolet/media

# ====== Supabase (only for JWT verification + DB access from migrated functions) ======
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_JWT_SECRET=super-secret-from-supabase-dashboard

# ====== SMTP (for send-order-status-email) ======
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@elmussolet.com
SMTP_PASS=changeme
SMTP_FROM="El Mussolet <noreply@elmussolet.com>"

# ====== CORS ======
# Comma-separated list of allowed origins for the frontend.
ALLOWED_ORIGINS=https://elmussolet.com,https://www.elmussolet.com
